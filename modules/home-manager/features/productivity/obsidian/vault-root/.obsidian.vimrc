" Colemak remaps to match Neovim/Vimium muscle memory
noremap n j
noremap N J
noremap e k
noremap E K
noremap i l
noremap I L
noremap j n
noremap J N
noremap k e
noremap K E
noremap l i
noremap L I

" Keep your Ctrl-p / Ctrl-e inversion consistent
noremap <C-p> <C-e>
noremap <C-e> <C-p>
noremap <C-P> <C-E>
noremap <C-E> <C-P>
